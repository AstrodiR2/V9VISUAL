-- === [ СИСТЕМА ESP ] ===

local function createESP(plr)

    local box = Drawing.new("Square")

    box.Visible = false

    box.Thickness = 1

    box.Filled = false

    

    local tracer = Drawing.new("Line")

    tracer.Visible = false

    tracer.Thickness = 1

    

    local name = Drawing.new("Text")

    name.Visible = false

    name.Size = 16

    name.Center = true

    name.Outline = true


    local conn

    conn = RunService.RenderStepped:Connect(function()

        if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr ~= lp then

            local hrp = plr.Character.HumanoidRootPart

            local pos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(hrp.Position)

            

            if onScreen then

                if _G.ESP_Boxes then

                    box.Size = Vector2.new(2000 / pos.Z, 3000 / pos.Z)

                    box.Position = Vector2.new(pos.X - box.Size.X / 2, pos.Y - box.Size.Y / 2)

                    box.Color = _G.VisualColor

                    box.Visible = true

                else box.Visible = false end

                

                if _G.ESP_Tracers then

                    tracer.From = Vector2.new(workspace.CurrentCamera.ViewportSize.X / 2, workspace.CurrentCamera.ViewportSize.Y)

                    tracer.To = Vector2.new(pos.X, pos.Y)

                    tracer.Color = _G.VisualColor

                    tracer.Visible = true

                else tracer.Visible = false end


                if _G.ESP_Names then

                    name.Position = Vector2.new(pos.X, pos.Y - (3500 / pos.Z) / 2 - 20)

                    name.Text = plr.Name

                    name.Color = Color3.new(1,1,1)

                    name.Visible = true

                else name.Visible = false end

            else

                box.Visible = false; tracer.Visible = false; name.Visible = false

            end

        else

            box.Visible = false; tracer.Visible = false; name.Visible = false

            if not plr.Parent then 

                box:Remove(); tracer:Remove(); name:Remove(); conn:Disconnect() 

            end

        end

    end)

end


-- === [ ТРЕЙЛЫ ] ===

local activeTrails = {}

local function addTrail(char)

    for _, t in pairs(activeTrails) do if t then t:Destroy() end end

    table.clear(activeTrails)


    local function makeT(part, groupName)

        if not part then return end

        local a0 = Instance.new("Attachment", part)

        a0.Position = Vector3.new(0, -0.5, 0)

        local a1 = Instance.new("Attachment", part)

        a1.Position = Vector3.new(0, 0.5, 0)

        local tr = Instance.new("Trail", part)

        tr.Attachment0 = a0 tr.Attachment1 = a1

        tr.Name = groupName

        tr.Enabled = false

        table.insert(activeTrails, tr)

    end


    makeT(char:WaitForChild("Left Arm", 2) or char:FindFirstChild("LeftUpperArm"), "Arms")

    makeT(char:WaitForChild("Right Arm", 2) or char:FindFirstChild("RightUpperArm"), "Arms")

    makeT(char:WaitForChild("Left Leg", 2) or char:FindFirstChild("LeftUpperLeg"), "Legs")

    makeT(char:WaitForChild("Right Leg", 2) or char:FindFirstChild("RightUpperLeg"), "Legs")

    makeT(char:WaitForChild("Torso", 2) or char:FindFirstChild("UpperTorso"), "Torso")


    RunService.Heartbeat:Connect(function()

        if not char.Parent then return end

        for _, tr in pairs(activeTrails) do

            if tr and tr.Parent then

                local isSelected = table.find(_G.TrailParts, tr.Name) ~= nil

                tr.Enabled = _G.TrailsEnabled and isSelected

                tr.Lifetime = _G.TrailLifetime

                tr.WidthScale = NumberSequence.new(0.5, 0.5 - math.clamp(_G.TrailSpeed, 0, 0.5))

                tr.Color = ColorSequence.new(_G.VisualColor)

            end

        end

    end)

end


-- === [ ФУНКЦИИ ВИЗУАЛА ] ===

local activeRGBObjects = {} -- НОВОЕ: Таблица для реал-тайм RGB клонов и волн


local function setNoCol(p)

    p.CanCollide = false p.CanTouch = false p.CanQuery = false p.Anchored = true p.Massless = true

end


local function createGhost(char)

    if not _G.MovementEffects then return end

    if not char:FindFirstChild("HumanoidRootPart") then return end

    char.Archivable = true

    local ghost = char:Clone()

    char.Archivable = false

    ghost.Parent = workspace

    for _, obj in pairs(ghost:GetDescendants()) do

        if obj:IsA("BasePart") then

            setNoCol(obj)

            obj.Material = Enum.Material.Neon

            obj.Color = _G.VisualColor

            obj.Transparency = 0.5

            table.insert(activeRGBObjects, obj) -- Добавляем в реал-тайм RGB

            TweenService:Create(obj, TweenInfo.new(0.8), {Transparency = 1}):Play()

        elseif not obj:IsA("SpecialMesh") then obj:Destroy() end

    end

    ghost:PivotTo(char.HumanoidRootPart.CFrame)

    task.delay(0.8, function() ghost:Destroy() end)

end


local function spawnWave(char)

    if not _G.MovementEffects then return end

    local root = char:FindFirstChild("HumanoidRootPart")

    if not root then return end

    local params = RaycastParams.new()

    params.FilterDescendantsInstances = {char}

    local ray = workspace:Raycast(root.Position, Vector3.new(0, -20, 0), params)

    local floorPos = ray and ray.Position or (root.Position - Vector3.new(0, 3, 0))

    local p = Instance.new("Part", workspace)

    p.Size = Vector3.new(1, 0.1, 1)

    p.Position = floorPos + Vector3.new(0, 0.05, 0)

    p.Color = _G.VisualColor

    p.Material = Enum.Material.Neon

    setNoCol(p)

    table.insert(activeRGBObjects, p) -- Добавляем в реал-тайм RGB

    local m = Instance.new("SpecialMesh", p)

    m.MeshType = Enum.MeshType.Sphere

    TweenService:Create(m, TweenInfo.new(0.8), {Scale = Vector3.new(35, 0, 35)}):Play()

    TweenService:Create(p, TweenInfo.new(0.8), {Transparency = 1}):Play()

    task.delay(0.8, function() p:Destroy() end)

end


local playerParts = {}

local function clearParts()

    for _, g in pairs(playerParts) do for _, p in pairs(g) do p:Destroy() end end

    table.clear(playerParts)

end


local function createParts(player)

    if not _G.ParticlesEnabled then return end

    local parts = {}

    for i = 1, _G.ParticleCount do

        local p = Instance.new("Part", workspace)

        p.Material = Enum.Material.Neon

        setNoCol(p)

        table.insert(parts, p)

    end

    playerParts[player] = parts

end


-- НОВОЕ: Удаление партиклов при выходе игрока

Players.PlayerRemoving:Connect(function(plr)

    if playerParts[plr] then

        for _, p in pairs(playerParts[plr]) do p:Destroy() end

        playerParts[plr] = nil

    end

end)


-- === [ РЕНДЕР ] ===

local accPart = Instance.new("Part")

accPart.Name = "V9_Accessory"

accPart.Material = Enum.Material.Neon

setNoCol(accPart)

local accMesh = Instance.new("SpecialMesh", accPart)


local mBlur = Lighting:FindFirstChild("V9_Blur") or Instance.new("BlurEffect", Lighting)

mBlur.Name = "V9_Blur"


local lastCF = workspace.CurrentCamera.CFrame


RunService.RenderStepped:Connect(function()

    -- Окружение

    if _G.SkyboxEnabled then

        Lighting.OutdoorAmbient = _G.SkyboxColor

        Lighting.Ambient = _G.SkyboxColor

        Lighting.FogColor = _G.SkyboxColor

    else

        Lighting.OutdoorAmbient = defaultLighting.OutdoorAmbient

        Lighting.Ambient = defaultLighting.Ambient

        Lighting.FogColor = defaultLighting.FogColor

    end


    -- Dynamic FOV

    if _G.DynFOV and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then

        local vel = lp.Character.HumanoidRootPart.Velocity.Magnitude

        local targetFOV = 70 + (vel / 3)

        workspace.CurrentCamera.FieldOfView = workspace.CurrentCamera.FieldOfView + (targetFOV - workspace.CurrentCamera.FieldOfView) * 0.1

    end


    -- Блюр

    if _G.BlurEnabled then

        local rel = workspace.CurrentCamera.CFrame:ToObjectSpace(lastCF)

        local _, y, _ = rel:ToEulerAnglesXYZ()

        mBlur.Size = math.clamp(math.abs(y) * (_G.BlurIntensity / 1.5), 0, 60)

    else mBlur.Size = 0 end

    lastCF = workspace.CurrentCamera.CFrame


    -- Аксессуар

    if _G.CurrentAcc ~= "None" and lp.Character and lp.Character:FindFirstChild("Head") then

        accPart.Parent = workspace

        accPart.Color = _G.VisualColor

        accPart.CFrame = lp.Character.Head.CFrame * CFrame.new(0, _G.AccY, 0) * CFrame.Angles(0, math.rad(_G.AccRot), 0)

        accMesh.Scale = Vector3.new(_G.AccScale, _G.AccScale, _G.AccScale)

        if _G.CurrentAcc == "Douli" then

            -- НОВОЕ: Заменено на реалистичную бамбуковую шляпу

            accMesh.MeshId = "rbxassetid://16949326"

            accMesh.TextureId = "rbxassetid://16949317"

        elseif _G.CurrentAcc == "Cap" then

            accMesh.MeshId = "rbxassetid://1028713"

            accMesh.TextureId = "" 

        end

    else accPart.Parent = nil end


    -- Партиклы (С учетом разброса)

    if not _G.ParticlesEnabled then clearParts() else

        for player, parts in pairs(playerParts) do

            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")

            if root then

                for i, p in pairs(parts) do

                    local t = tick() * _G.ParticleSpeed

                    local ang = t + (i * (math.pi * 2 / #parts))

                    

                    local currentRad = _G.ParticleRadius

                    local yOff = -2 + (i * (_G.ParticleHeight / #parts))


                    -- НОВОЕ: Логика разброса (Смещения по X/Z и Y)

                    if _G.ScatteredParticles then

                        currentRad = currentRad + (math.sin(i * 45.3) * (_G.ParticleRadius * 0.8))

                        yOff = math.cos(i * 22.1) * _G.ParticleHeight

                    end


                    p.Size = Vector3.new(_G.ParticleStretch, _G.ParticleStretch, _G.ParticleStretch)

                    p.CFrame = CFrame.new(root.Position + Vector3.new(math.cos(ang) * currentRad * _G.ParticleWidth, yOff, math.sin(ang) * currentRad))

                    p.Color = _G.VisualColor

                end

            end

        end

    end

end)


